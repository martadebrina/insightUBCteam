AU,CAAC,UAAU,CAAC,IAAI,SAAS,KAAK,UAAU,CAAC;QACrE,CAAC,CAAC,CAAC;QAEH,MAAM,YAAY,GAAG,eAAe,CAAC,GAAG,CAAC,KAAK,EAAE,SAAS,EAAE,EAAE;YAC5D,MAAM,IAAI,GAAG,GAAG,CAAC,IAAI,CAAC,SAAS,CAAC,CAAC;YACjC,IAAI,IAAI,EAAE;gBACT,MAAM,aAAa,GAAG,MAAM,IAAI,CAAC,KAAK,CAAC,QAAQ,CAAC,CAAC;gBACjD,OAAO,IAAI,CAAC,KAAK,CAAC,aAAa,CAAC,CAAC,MAAM,CAAC;aACxC;QACF,CAAC,CAAC,CAAC;QAEH,MAAM,eAAe,GAAG,MAAM,OAAO,CAAC,GAAG,CAAC,YAAY,CAAC,CAAC;QAExD,KAAK,MAAM,MAAM,IAAI,eAAe,EAAE;YACrC,KAAK,MAAM,OAAO,IAAI,MAAM,EAAE;gBAC7B,MAAM,UAAU,GAAG,IAAI,MAAM,CAAC,OAAO,CAAC,CAAC;gBACvC,YAAY,CAAC,SAAS,CAAC,UAAU,CAAC,CAAC;aACnC;SACD;QACD,IAAI,YAAY,CAAC,OAAO,CAAC,MAAM,KAAK,CAAC,EAAE;YACtC,MAAM,IAAI,6BAAY,CAAC,EAAE,CAAC,CAAC;SAC3B;QAGD,QAAQ,CAAC,GAAG,CAAC,EAAE,EAAE,YAAY,CAAC,CAAC;QAE/B,MAAM,IAAI,CAAC,gBAAgB,CAAC,QAAQ,CAAC,CAAC;IACvC,CAAC;IAEO,KAAK,CAAC,gBAAgB,CAAC,QAA+B;QAE7D,MAAM,aAAa,GAAG,KAAK,CAAC,IAAI,CAAC,QAAQ,CAAC,OAAO,EAAE,CAAC,CAAC;QAIrD,MAAM,EAAE,CAAC,SAAS,CAAC,QAAQ,CAAC,CAAC;QAE7B,MAAM,EAAE,CAAC,SAAS,CAAC,sBAAsB,EAAE,aAAa,CAAC,CAAC;IAC3D,CAAC;CACD;AAlKD,gCAkKC","sourcesContent":["import {\n\tIInsightFacade,\n\tInsightDataset,\n\tInsightDatasetKind,\n\tInsightResult,\n\tNotFoundError,\n\tInsightError,\n} from \"./IInsightFacade\";\nimport JSZip, { loadAsync } from \"jszip\";\nimport * as fs from \"fs-extra\";\n// import * as path from \"path\";\n\nclass Datasets {\n\t// private datasetMap: Map<string, DatasetInfo>;\n\n\tpublic courses: Course[];\n\tpublic numRows: number;\n\tpublic kind: InsightDatasetKind;\n\n\tconstructor() {\n\t\tthis.courses = [];\n\t\tthis.numRows = 0;\n\t\tthis.kind = InsightDatasetKind.Sections;\n\t}\n\n\tpublic addCourse(newCourse: Course): void {\n\t\tthis.courses.push(newCourse);\n\t\t++this.numRows;\n\t}\n}\n\nclass Course {\n\t// private sectionList: any[];\n\n\tpublic uuid: string;\n\tpublic id: string;\n\tpublic title: string;\n\tpublic instructor: string;\n\tpublic dept: string;\n\tpublic year: number;\n\tpublic avg: number;\n\tpublic pass: number;\n\tpublic fail: number;\n\tpublic audit: number;\n\n\tconstructor(section: any) {\n\t\t// check undefined variable\n\t\tif (!this.undefinedCheck(section)) {\n\t\t\tthrow new InsightError(\"Undefined variable\");\n\t\t}\n\t\ttry {\n\t\t\tthis.uuid = String(section.id);\n\t\t\tthis.id = String(section.Course);\n\t\t\tthis.title = String(section.title);\n\t\t\tthis.instructor = String(section.Professor);\n\t\t\tthis.dept = String(section.Subject);\n\t\t\tif (section.Section === \"overall\") {\n\t\t\t\tthis.year = 1900;\n\t\t\t} else {\n\t\t\t\tthis.year = this.anyToNum(section.Year);\n\t\t\t}\n\t\t\tthis.avg = this.anyToNum(section.Avg);\n\t\t\tthis.pass = this.anyToNum(section.Pass);\n\t\t\tthis.fail = this.anyToNum(section.Fail);\n\t\t\tthis.audit = this.anyToNum(section.Audit);\n\t\t} catch (_err) {\n\t\t\tthrow new InsightError(\"invalid variable type\");\n\t\t}\n\t}\n\tpublic undefinedCheck(c: any): boolean {\n\t\treturn (\n\t\t\tc.id === undefined ||\n\t\t\tc.Course === undefined ||\n\t\t\tc.title === undefined ||\n\t\t\tc.Professor === undefined ||\n\t\t\tc.Subject === undefined ||\n\t\t\tc.Section === undefined ||\n\t\t\tc.Year === undefined ||\n\t\t\tc.Avg === undefined ||\n\t\t\tc.Pass === undefined ||\n\t\t\tc.Fail === undefined ||\n\t\t\tc.Audit === undefined\n\t\t);\n\t}\n\n\tpublic anyToNum(n: any): number {\n\t\tconst num = Number(n);\n\t\tif (isNaN(num)) {\n\t\t\tthrow new InsightError(\"n is not a number\");\n\t\t}\n\t\treturn num;\n\t}\n}\n\nexport default class InsightFacade implements IInsightFacade {\n\tprivate datasets = new Map<string, Datasets>();\n\n\tpublic async addDataset(id: string, content: string, kind: InsightDatasetKind): Promise<string[]> {\n\t\tawait this.loadDatasetsFromDisk();\n\n\t\tif (!this.isValidId(id)) {\n\t\t\tthrow new InsightError(\"Invalid id\");\n\t\t}\n\n\t\t// verify content\n\t\t// const base64regex = /^([0-9a-zA-Z+/]{4})*(([0-9a-zA-Z+/]{2}==)|([0-9a-zA-Z+/]{3}=))?$/;\n\t\t// if (base64regex.test(content)) {\n\t\t// \tthrow new InsightError(\"content not base64\");\n\t\t// }\n\n\t\tif (kind !== InsightDatasetKind.Sections) {\n\t\t\tthrow new InsightError(\"kind not valid\");\n\t\t}\n\n\t\tif (this.datasets.has(id)) {\n\t\t\tthrow new InsightError(\"Dataset already exists\");\n\t\t}\n\n\t\tlet zipData: JSZip;\n\t\ttry {\n\t\t\tzipData = await loadAsync(content, { base64: true });\n\t\t\tconst files = zipData.folder(\"courses\");\n\t\t\tif (!files) {\n\t\t\t\tthrow new InsightError(\"no courses folder\");\n\t\t\t}\n\t\t\tif (files.length === 0) {\n\t\t\t\tthrow new InsightError(\"no content in files\");\n\t\t\t}\n\t\t\tawait this.parseZipFile(id, zipData, this.datasets);\n\t\t} catch (_err) {\n\t\t\tthrow new InsightError(\"Fail to unzip\");\n\t\t}\n\n\t\treturn Array.from(this.datasets.keys());\n\t}\n\n\tpublic async removeDataset(id: string): Promise<string> {\n\t\tawait this.loadDatasetsFromDisk();\n\n\t\tif (!this.isValidId(id)) {\n\t\t\tthrow new InsightError(\"Invalid id\");\n\t\t}\n\n\t\tif (!this.datasets.has(id)) {\n\t\t\tthrow new NotFoundError(`Dataset with id '${id}' not found`);\n\t\t}\n\n\t\tthis.datasets.delete(id);\n\n\t\tawait this.saveDatasetsDisk(this.datasets);\n\t\t\n\t\treturn id;\n\t}\n\n\tpublic async performQuery(query: unknown): Promise<InsightResult[]> {\n\t\tthrow new Error(`InsightFacadeImpl::performQuery() is unimplemented! - query=${query};`);\n\t}\n\n\tpublic async listDatasets(): Promise<InsightDataset[]> {\n\t\tawait this.loadDatasetsFromDisk();\n\n\t\tconst datasetsList: InsightDataset[] = [];\n\n\t\tfor (const [id, dataset] of this.datasets.entries()) {\n\t\t\tconst insightDataset: InsightDataset = {\n\t\t\t\tid: id,\n\t\t\t\tkind: dataset.kind,\n\t\t\t\tnumRows: dataset.numRows,\n\t\t\t};\n\t\t\tdatasetsList.push(insightDataset);\n\t\t}\n\n\t\treturn datasetsList;\n\t}\n\n\tprivate isValidId(id: string): boolean {\n\t\tconst trimmedId = id.trim();\n\t\treturn trimmedId.length > 0 && !trimmedId.includes(\"_\") && !trimmedId.includes(\" \");\n\t}\n\n\t// private async loadDatasetsFromDisk(): Promise<void> {\n\t// \tthrow new Error(\"Function not implemented.\");\n\t// }\n\n\tprivate async loadDatasetsFromDisk(): Promise<void> {\n\t\ttry {\n\t\t\tconst datasetsPath = `./data/Datasets.json`;\n\t\t\tconst exists = await fs.pathExists(datasetsPath);\n\t\t\tif (!exists) {\n\t\t\t\treturn;\n\t\t\t}\n\n\t\t\tconst datasetsArray: [string, Datasets][] = await fs.readJSON(datasetsPath);\n\n\t\t\t// Clear the current datasets map before loading\n\t\t\tthis.datasets.clear();\n\n\t\t\t// Repopulate the datasets map from the array read from the disk\n\t\t\tfor (const [id, dataset] of datasetsArray) {\n\t\t\t\tconst newDataset = new Datasets();\n\t\t\t\tnewDataset.courses = dataset.courses;\n\t\t\t\tnewDataset.numRows = dataset.numRows;\n\t\t\t\tnewDataset.kind = dataset.kind;\n\n\t\t\t\tthis.datasets.set(id, newDataset);\n\t\t\t}\n\t\t\t// console.log(this.datasets);\n\t\t} catch (_err) {\n\t\t\tthrow new InsightError(\"Error loading datasets from disk\");\n\t\t}\n\t}\n\n\tprivate async parseZipFile(id: string, zip: JSZip, datasets: Map<string, Datasets>): Promise<void> {\n\t\tconst dumpDatasets = new Datasets();\n\t\tconst zipContent = zip.files;\n\t\tconst keyContent = Object.keys(zipContent);\n\t\tconst filteredContent = keyContent.filter((checkPath: string) => {\n\t\t\treturn checkPath.startsWith(\"courses/\") && checkPath !== \"courses/\";\n\t\t});\n\n\t\tconst listPromises = filteredContent.map(async (checkPath) => {\n\t\t\tconst file = zip.file(checkPath);\n\t\t\tif (file) {\n\t\t\t\tconst stringContent = await file.async(\"string\");\n\t\t\t\treturn JSON.parse(stringContent).result;\n\t\t\t}\n\t\t});\n\n\t\tconst fulfillPromises = await Promise.all(listPromises);\n\n\t\tfor (const course of fulfillPromises) {\n\t\t\tfor (const section of course) {\n\t\t\t\tconst dumpCourse = new Course(section);\n\t\t\t\tdumpDatasets.addCourse(dumpCourse);\n\t\t\t}\n\t\t}\n\t\tif (dumpDatasets.courses.length === 0) {\n\t\t\tthrow new InsightError(\"\");\n\t\t}\n\n\t\t// set map\n\t\tdatasets.set(id, dumpDatasets);\n\n\t\tawait this.saveDatasetsDisk(datasets);\n\t}\n\n\tprivate async saveDatasetsDisk(datasets: Map<String, Datasets>): Promise<void> {\n\t\t// Convert Map to an object before writing, from chatGPT\n\t\tconst datasetsArray = Array.from(datasets.entries());\n\t\t// console.log(this.datasets);\n\n\t\t// Ensure the directory exists\n\t\tawait fs.ensureDir(\"./data\");\n\n\t\tawait fs.writeJSON(`./data/Datasets.json`, datasetsArray);\n\t}\n}\n"]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"57640c8203198e24816cff3e1743eb808bcfc13e","contentHash":"f26028cabc4248757c259612d6e73c10497d08116889a69435d93906492e54d5"}}