{
	"title": "Min Sum Avg Count Transformation with 1 col sort",
	"input": {
		"WHERE": {
			"AND": [
				{
					"IS": {
						"rooms_furniture": "*Tables*"
					}
				},
				{
					"GT": {
						"rooms_seats": 300
					}
				}
			]
		},
		"OPTIONS": {
			"COLUMNS": ["rooms_shortname", "minSeats", "totalSeats", "expectedSeats", "numDifferentLayouts"],
			"ORDER": {
				"dir": "DOWN",
				"keys": ["minSeats"]
			}
		},
		"TRANSFORMATIONS": {
			"GROUP": ["rooms_shortname"],
			"APPLY": [
				{
					"minSeats": {
						"MIN": "rooms_seats"
					}
				},
				{
					"totalSeats": {
						"SUM": "rooms_seats"
					}
				},
				{
					"expectedSeats": {
						"AVG": "rooms_seats"
					}
				},
				{
					"numDifferentLayouts": {
						"COUNT": "rooms_seats"
					}
				}
			]
		}
	},
	"errorExpected": false,
	"expected": [
		{ "rooms_shortname": "OSBO", "minSeats": 442, "totalSeats": 442, "expectedSeats": 442, "numDifferentLayouts": 1 },
		{ "rooms_shortname": "HEBB", "minSeats": 375, "totalSeats": 375, "expectedSeats": 375, "numDifferentLayouts": 1 },
		{ "rooms_shortname": "LSC", "minSeats": 350, "totalSeats": 700, "expectedSeats": 350, "numDifferentLayouts": 1 }
	]
}
